// HotelTrack — Prisma schema
// Docs: https://pris.ly/d/prisma-schema
//
// CRITICAL (see CLAUDE.md): HotelTrack is multi-tenant. Every model except
// `Agency` carries an `agencyId` column and is indexed on it, and every query
// MUST filter by `agencyId` so that no agency can ever read another's data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7: the connection URL is NOT set here anymore. The CLI reads it from
  // `prisma.config.ts` (datasource.url -> env("DATABASE_URL")), and the runtime
  // client connects via the @prisma/adapter-pg driver adapter (see lib/prisma.ts).
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
//
// Enums are used only for fields whose full set of allowed values was specified.
// Open-ended state fields (subscriptionStatus, plan, snippetStatus, content
// status, meta token status, deviceType) are kept as String + @default so their
// vocabularies can grow (e.g. as billing tiers are finalized) without an enum
// migration.
// ─────────────────────────────────────────────────────────────────────────────

enum MemberRole {
  admin
  analyst
}

enum ConversionMethod {
  url_change
  same_page
  both
}

enum ContentType {
  organic
  paid_ad
  influencer
  story
}

enum Platform {
  instagram
  facebook
  youtube
}

enum EventType {
  visit
  conversion
}

enum AlertType {
  performance_drop
  snippet_error
  meta_token_expiry
  weekly_summary
  budget_threshold
}

enum TokenAuditAction {
  created
  decrypted
  refreshed
  rotated
  deleted
  failed_decrypt
  // Hotel lifecycle (soft delete / restore). Lowercase to match the values
  // above; the server actions log these for the audit trail.
  hotel_soft_deleted
  hotel_restored
}

// How an agency obtained/shared the setup guide PDF, for usage analytics.
//   direct — downloaded the PDF file itself
//   link   — copied the public /setup-guide link to share
//   email  — opened an email pre-filled with the link
enum GuideDownloadMethod {
  direct
  link
  email
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

model Agency {
  id                 String   @id @default(cuid())
  name               String
  email              String
  // Billing is Razorpay (INR). The customer id is populated by Razorpay after the
  // first authorisation payment; the subscription id is the sub_… we open Checkout
  // against. subscriptionExpiresAt mirrors the current billing cycle's end.
  razorpayCustomerId     String?  @unique
  razorpaySubscriptionId String?  @unique
  // Lifecycle: inactive (pre-subscription) | created | active | paused |
  // cancelled | completed | expired. Only `active` unlocks the dashboard.
  subscriptionStatus    String    @default("inactive")
  plan                  String    @default("starter") // starter | growth | agency
  subscriptionExpiresAt DateTime?
  // Set by a super admin to suspend the agency, independent of Razorpay billing.
  // When set, access to the agency dashboard is blocked (see the agency layout).
  suspendedAt        DateTime?
  // ── Budget-alert notification settings (see lib/budget-alerts.ts) ──
  // One Slack Incoming Webhook per agency; all budget alerts post to that one
  // channel. Email alerts go to alertEmailAddress (defaults to the owner email).
  slackWebhookUrl    String?
  slackEnabled       Boolean   @default(false)
  slackLastTestAt    DateTime?
  slackLastTestStatus String? // "success" | an error message (for the UI)
  alertEmailAddress  String?
  emailAlertsEnabled Boolean   @default(false)
  createdAt          DateTime @default(now())

  members           AgencyMember[]
  hotelClients      HotelClient[]
  contentPieces     ContentPiece[]
  trackingEvents    TrackingEvent[]
  touchpoints       Touchpoint[]
  metaTokens        MetaToken[]
  adSnapshots       AdSnapshot[]
  couponRedemptions CouponRedemption[]
  reports           Report[]
  alerts            Alert[]
  shareLinks        ShareLink[]
  instagramConnections InstagramConnection[]
  socialSnapshots   SocialSnapshot[]
  postSnapshots     PostSnapshot[]
  storySnapshots    StorySnapshot[]
  instagramAudience InstagramAudience[]
  gaConnections     GoogleAnalyticsConnection[]
  gaSnapshots       GaSnapshot[]
  gaSourceBreakdowns GaSourceBreakdown[]
  tokenAuditLogs    TokenAuditLog[]
  backfillJobs      BackfillJob[]
  backfillLogs      BackfillLog[]
  syncFailures      SyncFailure[]
  adCampaignSnapshots  AdCampaignSnapshot[]
  campaignPerformances CampaignPerformance[]
  guideDownloads       GuideDownload[]
  hotelShareAccesses   HotelShareAccess[]
  budgetAlerts         BudgetAlert[]
  ga4Connections       Ga4Connection[]
  ga4Snapshots         Ga4Snapshot[]
}

model AgencyMember {
  id        String     @id @default(cuid())
  agencyId  String
  clerkId   String     @unique // maps the Clerk user -> this membership
  email     String
  name      String
  role      MemberRole
  createdAt DateTime   @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
}

model HotelClient {
  id                 String           @id @default(cuid())
  agencyId           String
  name               String
  websiteUrl         String
  // Which platform the hotel's website runs on, used to show the right install
  // guide (WordPress / Shopify / Other). String + @default so the set of
  // supported platforms can grow without an enum migration.
  sitePlatform       String           @default("other")
  contactName        String
  contactEmail       String
  siteId             String           @unique @default(cuid()) // public id embedded in the tracking snippet
  conversionMethod   ConversionMethod
  thankYouUrlPattern String? // for conversionMethod = url_change / both
  successPhrase      String? // for conversionMethod = same_page / both
  successSelector    String? // for conversionMethod = same_page / both
  snippetStatus      String           @default("not_installed")
  // Meta ad account (act_<id>) mapped to this hotel on /agency/settings, so its
  // dashboard can pull ad spend/ROI for the right account. Nullable until mapped.
  metaAdAccountId    String?
  // ── Monthly ad-budget tracking (see lib/budget.ts) ──
  // monthlyAdBudget is stored in PAISE (₹2,00,000 = 20000000) so spend↔budget
  // maths stays integer. budgetResetDay (1–28) is the day of month the budget
  // window restarts on. Threshold alerts (80/90/100%) fire once per BudgetAlert.
  monthlyAdBudget        Int?
  budgetTrackingEnabled  Boolean        @default(false)
  budgetResetDay         Int            @default(1)
  // Ad accounts previously mapped to this hotel (oldest→newest), recorded when
  // the agency switches the hotel to a DIFFERENT account. Their old AdSnapshot/
  // campaign data is archived (kept, hidden) and listed in Connection History.
  // AGENCY-ONLY — never exposed on hotel-facing views.
  previousAdAccountIds String[]       @default([])
  // When the CURRENT Meta ad account was mapped to this hotel. Drives the
  // "sync in progress" fresh-start state right after an account change.
  metaAccountConnectedAt DateTime?
  lastEventAt        DateTime?
  // When the Meta ad sync (/api/meta/sync) last wrote AdSnapshots for this hotel.
  // Null until the first successful sync. Surfaced as "last sync" on the dashboard.
  lastSyncedAt       DateTime?
  // ── Hotel-owner share link (public, read-only dashboard at /h/<shareToken>) ──
  // A persistent, unguessable 256-bit token (crypto.randomBytes(32).hex). Null
  // until the agency generates one. Regenerating overwrites it (the old URL dies);
  // revoking flips shareTokenRevoked so the URL 404s without discarding the token.
  // showAdSpendToHotel gates whether spend/True-ROAS figures are revealed to the
  // hotel — default OFF, because most agencies hide their ad spend from clients.
  shareToken          String?         @unique
  shareTokenCreatedAt DateTime?
  shareTokenRevoked   Boolean         @default(false)
  showAdSpendToHotel  Boolean         @default(false)
  // ── Soft delete (admin-only; reversible via restoreHotel) ──
  // deletedAt null = active. When set, the hotel is hidden everywhere and all
  // syncing stops, but every row (tokens, events, attribution, snapshots) is
  // preserved so it can be restored. deletedByAgencyMemberId records which admin
  // performed it; deletionReason is an optional note (capped to 500 chars).
  deletedAt               DateTime?
  deletedByAgencyMemberId String?
  deletionReason          String?
  createdAt          DateTime         @default(now())

  agency         Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  metaToken      MetaToken?
  contentPieces  ContentPiece[]
  trackingEvents TrackingEvent[]
  touchpoints    Touchpoint[]
  sessions       Session[]
  adSnapshots    AdSnapshot[]
  reports         Report[]
  alerts          Alert[]
  shareLinks      ShareLink[]
  instagramConnections InstagramConnection[]
  socialSnapshots SocialSnapshot[]
  postSnapshots   PostSnapshot[]
  storySnapshots  StorySnapshot[]
  instagramAudience InstagramAudience[]
  gaConnections   GoogleAnalyticsConnection[]
  gaSnapshots     GaSnapshot[]
  gaSourceBreakdowns GaSourceBreakdown[]
  tokenAuditLogs  TokenAuditLog[]
  adCampaignSnapshots  AdCampaignSnapshot[]
  campaignPerformances CampaignPerformance[]
  guideDownloads       GuideDownload[]
  shareAccesses        HotelShareAccess[]
  budgetAlerts         BudgetAlert[]
  ga4Connection        Ga4Connection?
  ga4Snapshots         Ga4Snapshot[]

  @@index([agencyId])
}

// Audit trail for every view of a hotel's public /h/<shareToken> dashboard, so
// the agency can see "your hotel viewed the dashboard 4 times this week". The
// visitor IP is stored ONLY as a salted SHA-256 hash (ipHash) — never the raw
// address — for privacy. Multi-tenant: carries agencyId like every other table.
model HotelShareAccess {
  id            String   @id @default(cuid())
  agencyId      String
  hotelClientId String
  accessedAt    DateTime @default(now())
  ipHash        String? // salted SHA-256 of the client IP; never the raw IP
  userAgent     String?

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([hotelClientId, accessedAt]) // "views in last 30 days" + "last viewed"
}

model ContentPiece {
  id             String      @id @default(cuid())
  agencyId       String
  hotelClientId  String
  title          String
  contentType    ContentType
  platform       Platform
  destinationUrl String
  utmLink        String
  couponCode     String?
  influencerName String?
  status         String      @default("active")
  createdAt      DateTime    @default(now())

  agency            Agency             @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient       HotelClient        @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)
  couponRedemptions CouponRedemption[]

  @@index([agencyId])
  @@index([hotelClientId])
  @@index([couponCode])
}

model TrackingEvent {
  id              String    @id @default(cuid())
  // agencyId is NOT in the original Step 2 field list, but the multi-tenancy
  // rule requires every non-Agency model to carry it. Denormalized here (from
  // HotelClient.agencyId at write time) so tenant filtering stays a direct index hit.
  agencyId        String
  hotelClientId   String
  eventType       EventType
  // UTM params are nullable: direct/untagged visits legitimately have none.
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  pageUrl         String
  conversionValue Decimal?  @db.Decimal(12, 2)
  sessionId       String
  // Persistent per-browser id from the snippet's _ht_vid cookie (30-day sliding).
  // Nullable: pre-multi-touch rows and old snippet payloads have none.
  visitorId       String?
  deviceType      String
  createdAt       DateTime  @default(now())

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)
  // Touchpoints captured for a conversion event (multi-touch journey).
  touchpoints Touchpoint[]

  @@index([agencyId])
  @@index([hotelClientId])
  @@index([hotelClientId, eventType, createdAt]) // funnel queries over time
  @@index([sessionId]) // stitch a visit to its later conversion
}

// One row per touchpoint in a visitor's journey, captured by the snippet's
// _ht_journey cookie and flushed on conversion. Linked to the conversion's
// TrackingEvent via conversionId. Multi-tenant (agencyId, RLS) like every table.
model Touchpoint {
  id            String   @id @default(cuid())
  agencyId      String
  hotelClientId String
  // Persistent visitor id (snippet _ht_vid). Groups touchpoints across sessions.
  visitorId     String
  // The conversion this journey belongs to. Null only transiently; set at flush.
  conversionId  String?
  // 1-based order within the journey (1 = first touch).
  position      Int
  timestamp     DateTime
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  referrer      String?
  landingPage   String?
  createdAt     DateTime @default(now())

  agency      Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient   @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)
  conversion  TrackingEvent? @relation(fields: [conversionId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([hotelClientId])
  @@index([visitorId])
  @@index([conversionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Visitor journey tracking (snippet v2) — page-by-page capture per session.
//
// A Session is one browsing session (snippet `sess_…` id from sessionStorage,
// 30-min inactivity window). Each PageView is one page within that session with
// its time-on-page and exit reason. This is ADDITIVE to TrackingEvent (every
// pageview still writes a `visit` TrackingEvent, so existing dashboards keep
// working). Multi-tenant: both carry agencyId (denormalized for fast scoped
// reads) like every other table. `id` is the snippet-supplied string — NOT a
// cuid — so a session can be upserted by the id the browser already holds.
// ─────────────────────────────────────────────────────────────────────────────

model Session {
  id            String    @id // 'sess_' + uuid (snippet-supplied)
  visitorId     String
  hotelClientId String
  agencyId      String // denormalized for fast tenant-scoped queries
  startedAt     DateTime
  endedAt       DateTime? // null while the session is still active
  landingPath   String // first pagePath of the session
  exitPath      String? // last pagePath seen
  pageViewCount Int       @default(0)
  totalTimeMs   Int       @default(0)
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  referrer      String?
  userAgent     String?

  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)
  pageViews   PageView[]

  @@index([hotelClientId])
  @@index([agencyId])
  @@index([visitorId])
  @@index([startedAt])
  @@index([hotelClientId, startedAt]) // the dashboard's per-hotel "recent sessions" read
}

model PageView {
  id             String    @id @default(cuid())
  sessionId      String
  visitorId      String
  hotelClientId  String
  agencyId       String
  pagePath       String
  pageTitle      String?
  referrer       String?
  enteredAt      DateTime
  exitedAt       DateTime? // null until the page_exit event arrives
  timeOnPageMs   Int? // computed when page_exit arrives
  exitReason     String? // 'navigation' | 'unload' | 'inactivity_timeout'
  viewportWidth  Int?
  viewportHeight Int?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([hotelClientId])
  @@index([agencyId])
  @@index([visitorId])
  @@index([enteredAt])
  @@index([pagePath])
}

// How a MetaToken was obtained. Both produce the same end state (an encrypted,
// validated agency token); OAUTH tokens can be auto-refreshed, manual ones can't.
enum MetaTokenSource {
  OAUTH
  MANUAL_LONG_LIVED
}

model MetaToken {
  id             String   @id @default(cuid())
  agencyId       String
  // One MetaToken per hotel (like InstagramConnection / Ga4Connection). Each
  // hotel owns its own Meta Ads token, so hotels in SEPARATE Meta accounts no
  // longer overwrite each other. agencyId is kept for tenant scoping (every row
  // is still scoped to an agency) — see @@unique([hotelClientId]) below.
  hotelClientId  String
  encryptedToken String // AES-256-GCM ciphertext (base64). NEVER log or expose.
  tokenExpiresAt DateTime
  status         String   @default("disconnected")
  createdAt      DateTime @default(now())

  // Connection method + OAuth metadata. tokenSource defaults to MANUAL so every
  // pre-existing row keeps its meaning after the migration.
  tokenSource               MetaTokenSource @default(MANUAL_LONG_LIVED)
  oauthScopes               String[]        @default([])
  refreshableViaOAuth       Boolean         @default(false)
  connectedFacebookUserId   String?
  connectedFacebookUserName String?
  // Soft-disconnect bookkeeping + refresh/expiry-warning state.
  disconnectedAt     DateTime?
  lastRefreshedAt    DateTime?
  // Dedup for manual-token expiry emails: null | "14d" | "7d" | "expired".
  expiryWarningStage String?

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId]) // one Meta token per hotel
  @@index([agencyId])
}

model AdSnapshot {
  id             String   @id @default(cuid())
  agencyId       String
  hotelClientId  String
  metaAccountId  String
  date           DateTime @db.Date
  spend          Decimal  @db.Decimal(12, 2)
  impressions    Int
  reach          Int
  clicks         Int
  ctr            Float
  cpc            Decimal  @db.Decimal(12, 4)
  cpm            Decimal  @db.Decimal(12, 4)
  conversions    Int
  roas           Float
  pixelPurchases Int
  pixelLeads     Int
  pixelPageViews Int
  // ── Ad-account-change archiving (see lib/meta-archive.ts) ──
  // When an agency re-maps a hotel to a DIFFERENT Meta ad account, the old
  // account's rows are archived (not deleted) so the dashboard shows only the
  // new account's data. Dashboard reads filter archived = false by default.
  archived       Boolean   @default(false)
  archivedAt     DateTime?
  archivedReason String? // "account_changed" | "manual"

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  // One snapshot per hotel per AD ACCOUNT per day. metaAccountId is part of the
  // key so an archived old-account row and a fresh new-account row can coexist
  // for the same date (the old data is kept, just hidden).
  @@unique([hotelClientId, metaAccountId, date])
  @@index([agencyId])
  @@index([hotelClientId])
  @@index([hotelClientId, archived]) // dashboard reads filter on archived
}

// Campaign-level Meta insights — one row per hotel per campaign per day
// (AdSnapshot stays account-level; this adds the campaign_name dimension that
// campaign↔booking attribution joins on).
model AdCampaignSnapshot {
  id             String   @id @default(cuid())
  agencyId       String
  hotelClientId  String
  // Which Meta ad account this campaign belongs to. Nullable for rows written
  // before account-change archiving existed (backfilled by the migration from
  // the hotel's then-current mapping). Used to archive/restore by account.
  metaAccountId  String?
  metaCampaignId String
  campaignName   String
  date           DateTime @db.Date
  spend          Decimal  @db.Decimal(12, 2)
  impressions    Int
  clicks         Int
  // Meta-reported pixel purchases for this campaign-day.
  conversions    Int
  // Meta-reported purchase value for this campaign-day.
  purchaseValue  Decimal  @db.Decimal(12, 2)
  // Account-change archiving (see lib/meta-archive.ts + AdSnapshot above).
  archived       Boolean   @default(false)
  archivedAt     DateTime?
  archivedReason String?

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId, metaCampaignId, date]) // idempotent re-sync per campaign-day
  @@index([agencyId])
  @@index([hotelClientId, date])
  @@index([hotelClientId, archived])
}

// Materialized campaign↔booking attribution, refreshed after every Meta sync
// (see lib/campaign-attribution.ts). One row per hotel per campaign per day;
// the "Direct / Unattributed" bucket uses campaignKey UNATTRIBUTED_KEY.
model CampaignPerformance {
  id                      String   @id @default(cuid())
  agencyId                String
  hotelClientId           String
  date                    DateTime @db.Date
  // Lowercased campaignName — the case-insensitive join key (also dedupes
  // Meta campaigns whose names differ only by case).
  campaignKey             String
  campaignName            String
  metaCampaignId          String?
  metaSpend               Decimal  @db.Decimal(12, 2)
  metaReportedConversions Int
  metaReportedRevenue     Decimal  @db.Decimal(12, 2)
  realBookings            Int
  realBookingValue        Decimal  @db.Decimal(12, 2)
  // realBookingValue / metaSpend. Null when there is no spend that day.
  realRoas                Float?
  // ((realBookings − metaReportedConversions) / metaReportedConversions) × 100.
  // Null when Meta reported zero conversions.
  variancePct             Float?
  // Which Meta ad account these numbers came from (nullable; backfilled by the
  // migration). Lets the materialized attribution be archived/restored per
  // account on an account change, alongside AdSnapshot/AdCampaignSnapshot.
  metaAccountId           String?
  archived                Boolean   @default(false)
  archivedAt              DateTime?
  archivedReason          String?
  computedAt              DateTime @default(now())

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  // metaAccountId is part of the key so an archived old-account row and a fresh
  // new-account row with the same campaign name on the same date don't collide
  // (campaignKey is a name, unlike AdCampaignSnapshot's globally-unique id).
  @@unique([hotelClientId, date, campaignKey, metaAccountId], map: "CampaignPerformance_perAccount_key")
  @@index([agencyId])
  @@index([hotelClientId, date])
  @@index([hotelClientId, archived])
}

// One row per (hotel, threshold, budget-month) the moment a monthly ad-budget
// threshold (80/90/100%) is first crossed — the dedup guard so each threshold
// alerts at most once per month. notificationsSent records which of the three
// channels (in-app / email / slack) delivered. Multi-tenant: carries agencyId.
model BudgetAlert {
  id                String   @id @default(cuid())
  agencyId          String
  hotelClientId     String
  threshold         Int // 80 | 90 | 100
  monthKey          String // budget-month start, "YYYY-MM"
  spendAtTrigger    Int // paise
  budgetAtTrigger   Int // paise
  triggeredAt       DateTime  @default(now())
  acknowledgedAt    DateTime?
  notificationsSent Json // { inApp: bool, email: bool, slack: bool }

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId, threshold, monthKey]) // fire once per threshold per month
  @@index([agencyId])
  @@index([hotelClientId])
}

model CouponRedemption {
  id             String   @id @default(cuid())
  agencyId       String
  contentPieceId String
  redemptionDate DateTime
  orderValue     Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  agency       Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  contentPiece ContentPiece @relation(fields: [contentPieceId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([contentPieceId])
}

model Report {
  id                 String    @id @default(cuid())
  agencyId           String
  hotelClientId      String
  dateRangeStart     DateTime
  dateRangeEnd       DateTime
  pdfUrl             String?
  shareLink          String?   @unique // public, shareable token
  shareLinkExpiresAt DateTime?
  createdAt          DateTime  @default(now())

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([hotelClientId])
}

// Email alert history. One row per alert we raised (and tried to email), so the
// agency can audit what fired and when at /agency/alerts. Multi-tenant: every
// row carries agencyId. hotelClientId is null for agency-wide alerts (the weekly
// summary); it's SetNull-on-delete so removing a hotel keeps the audit trail.
model Alert {
  id            String    @id @default(cuid())
  agencyId      String
  hotelClientId String?
  type          AlertType
  severity      String    @default("warning") // info | warning | critical
  title         String
  message       String    @db.Text
  // Recipient + delivery outcome of the email sent for this alert.
  emailTo       String?
  emailStatus   String    @default("pending") // pending | sent | failed | skipped
  emailError    String?
  createdAt     DateTime  @default(now())

  agency      Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient? @relation(fields: [hotelClientId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([agencyId, type, createdAt]) // dedup lookups + history listing
  @@index([hotelClientId])
}

// Tamper-evident audit trail for every encrypt/decrypt of a stored secret
// (see lib/token-audit.ts). Multi-tenant: each row carries the agencyId whose
// token was handled. `actorId` is the Clerk user id of the acting member (null
// for cron/system/CLI), and `source` records the calling context (the route or
// server action). Failed decryptions are logged with success=false + a reason;
// a burst of them triggers a security alert email.
model TokenAuditLog {
  id            String           @id @default(cuid())
  agencyId      String
  hotelClientId String?
  tokenType     String // meta_ads | instagram | ga_credentials | …
  action        TokenAuditAction
  success       Boolean
  errorReason   String?
  ipAddress     String?
  userAgent     String?
  actorId       String? // Clerk user id of the acting member; null = system/cron
  source        String? // calling context, e.g. "action:saveMetaToken"
  createdAt     DateTime         @default(now())

  agency      Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient? @relation(fields: [hotelClientId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([agencyId, action, createdAt]) // per-agency history + filtering
  @@index([action, success, createdAt]) // failed-decrypt threshold scan
  @@index([createdAt])
  @@index([hotelClientId])
}

// A public, UUID-addressed link to a read-only view of one hotel's dashboard, so
// an agency can share results with the hotel owner without giving them a login.
// The `token` is the unguessable id in the /share/<token> URL. Optional password
// (scrypt hash), expires after a window, and is revocable (revokedAt) anytime.
model ShareLink {
  id            String    @id @default(cuid())
  agencyId      String
  hotelClientId String
  token         String    @unique @default(uuid()) // the public id in /share/<token>
  passwordHash  String? // scrypt "salt:hash"; null = no password
  expiresAt     DateTime
  revokedAt     DateTime?
  lastViewedAt  DateTime?
  viewCount     Int       @default(0)
  createdAt     DateTime  @default(now())

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([hotelClientId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Instagram organic — SEPARATE from the Meta *Ads* integration (MetaToken/
// AdSnapshot above). Connected via the "Instagram API with Instagram Login"
// OAuth flow (IGAA tokens on graph.instagram.com) — NO Facebook Page involved.
// One InstagramConnection per hotel. SocialSnapshot stores daily account
// metrics; PostSnapshot stores per-post metrics.
//
// tokenType is a String (not an enum) per this schema's convention for
// open-ended vocabularies: today it's always "igaa_direct"; rows from the
// retired EAA-via-Page flow were stamped "eaa_via_page" + status
// "deprecated_eaa" by the rename migration and are never used again.
// ─────────────────────────────────────────────────────────────────────────────

model InstagramConnection {
  id             String    @id @default(cuid())
  agencyId       String
  hotelClientId  String
  tokenType      String    @default("igaa_direct")
  igUserId       String // the Instagram user id returned by the IGAA flow
  username       String?
  igAccountType  String? // BUSINESS | CREATOR (PERSONAL is rejected at connect)
  profilePicUrl  String?
  encryptedToken String // AES-256-GCM ciphertext (base64). NEVER log or expose.
  tokenExpiresAt DateTime?
  // active | error | deprecated_eaa. "error" carries errorMessage and is set by
  // the sync when a connection fails; reconnecting via OAuth resets to active.
  status         String    @default("active")
  errorMessage   String?
  lastSyncedAt   DateTime?
  // When the weekly refresh cron last rolled the 60-day IGAA token forward.
  lastRefreshedAt DateTime?
  // Defensive surfacing: set true when an API call returns an auth failure so the
  // dashboard can show a one-click reconnect banner. lastErrorReason captures the
  // raw provider error. Cleared on a successful (re)connect or sync.
  requiresReconnect Boolean  @default(false)
  lastErrorReason   String?
  createdAt      DateTime  @default(now())

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId]) // one Instagram connection per hotel
  @@index([agencyId])
  @@index([hotelClientId])
}

model SocialSnapshot {
  id            String   @id @default(cuid())
  agencyId      String
  hotelClientId String
  date          DateTime @db.Date
  followers     Int      @default(0)
  reach         Int      @default(0)
  impressions   Int      @default(0)
  // "views" — the v22+ successor to account impressions (content plays/displays
  // across reels, posts, stories). impressions is retired and stays 0 on new rows.
  views         Int      @default(0)
  profileViews  Int      @default(0)
  // Daily "website_clicks" account metric (link-in-bio / website button taps).
  // Dropped gracefully by the sync if a Graph version no longer accepts it.
  websiteClicks Int      @default(0)
  engagement    Int      @default(0)

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId, date]) // one snapshot per hotel per day
  @@index([agencyId])
  @@index([hotelClientId])
}

// Follower demographics from the Instagram Graph `follower_demographics` insight
// (breakdown by country / age / gender). One row per (hotel, breakdown,
// dimension), refreshed each sync. Best-effort: the API only returns these for
// accounts with 100+ followers, so this table may legitimately be empty.
model InstagramAudience {
  id            String   @id @default(cuid())
  agencyId      String
  hotelClientId String
  // "country" | "age" | "gender"
  breakdown     String
  // The dimension value, e.g. "IN", "25-34", "F".
  dimension     String
  value         Int      @default(0)
  syncedAt      DateTime @default(now())

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId, breakdown, dimension])
  @@index([agencyId])
  @@index([hotelClientId])
}

model PostSnapshot {
  id            String    @id @default(cuid())
  agencyId      String
  hotelClientId String
  mediaId       String
  caption       String?   @db.Text
  // Normalised to one of: "image" | "video" | "carousel" | "reels".
  // The Graph API returns IMAGE / VIDEO / CAROUSEL_ALBUM (with REELS distinguished
  // by media_product_type=REELS); we normalise at write time so the dashboard
  // filter has a stable, lowercase value to match.
  mediaType     String?
  permalink     String?
  postedAt      DateTime?
  impressions   Int       @default(0)
  reach         Int       @default(0)
  // Likes + comments come from /{ig-user-id}/media (like_count, comments_count),
  // not from /insights. `engagement` is the Meta-reported aggregate (sum-of-parts
  // plus the platform's own definition) and is kept alongside the raw counts.
  likes         Int       @default(0)
  comments      Int       @default(0)
  engagement    Int       @default(0)
  saves         Int       @default(0)
  shares        Int       @default(0)
  videoViews    Int       @default(0)
  fetchedAt     DateTime  @default(now())

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId, mediaId]) // latest metrics per post
  @@index([agencyId])
  @@index([hotelClientId])
}

// Instagram Stories. Stories only live ~24 hours on the platform — once they
// expire they're gone from the Graph API, so the dedicated /api/social/sync-stories
// cron runs every 2 hours (not 6h like posts) to capture each story's final
// metrics before the API drops it. We then KEEP the StorySnapshot row forever,
// even after the story disappears from Instagram, so historical reporting works.
model StorySnapshot {
  id            String    @id @default(cuid())
  agencyId      String
  hotelClientId String
  storyId       String // Instagram media id of the story
  postedAt      DateTime?
  mediaType     String? // normalised: "image" | "video"
  reach         Int       @default(0)
  impressions   Int       @default(0)
  tapsForward   Int       @default(0) @map("taps_forward")
  tapsBack      Int       @default(0) @map("taps_back")
  exits         Int       @default(0)
  replies       Int       @default(0)
  fetchedAt     DateTime  @default(now())

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId, storyId])
  @@index([agencyId])
  @@index([hotelClientId])
  @@index([postedAt]) // for the "last 30 days" dashboard filter
}

// ─────────────────────────────────────────────────────────────────────────────
// Google Analytics 4 — the third data source per hotel (alongside Meta Ads and
// Instagram). The hotel already runs GA4 on its website; we ingest those daily
// rollups to put TOTAL website performance next to HotelTrack's snippet-based
// attribution.
//
// Credentials are a Google Cloud service-account JSON, encrypted with the same
// AES-256-GCM utility as Meta tokens (see lib/encryption.ts). The service
// account must be added as a Viewer on the GA4 property in the GA Admin UI.
// ─────────────────────────────────────────────────────────────────────────────

model GoogleAnalyticsConnection {
  id                   String    @id @default(cuid())
  agencyId             String
  hotelClientId        String
  propertyId           String // GA4 numeric property id, e.g. "123456789"
  encryptedCredentials String    @db.Text // AES-256-GCM ciphertext of the full service-account JSON
  status               String    @default("disconnected")
  lastSyncedAt         DateTime?
  createdAt            DateTime  @default(now())

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId]) // one GA connection per hotel
  @@index([agencyId])
}

model GaSnapshot {
  id                  String   @id @default(cuid())
  agencyId            String
  hotelClientId       String
  date                DateTime @db.Date
  totalUsers          Int      @default(0)
  newUsers            Int      @default(0)
  sessions            Int      @default(0)
  // GA4 returns bounceRate + conversionRate as 0..1 floats. avgSessionDuration
  // is seconds. We keep them as float for easy aggregation across days.
  bounceRate          Float    @default(0)
  avgSessionDuration  Float    @default(0)
  pageviews           Int      @default(0)
  conversions         Int      @default(0)
  conversionRate      Float    @default(0)

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId, date]) // one snapshot per hotel per day
  @@index([agencyId])
  @@index([hotelClientId])
}

model GaSourceBreakdown {
  id            String   @id @default(cuid())
  agencyId      String
  hotelClientId String
  date          DateTime @db.Date
  // Normalised source key: "instagram" | "facebook" | "google_organic" |
  // "google_paid" | "direct" | "email" | "referral" | "other".
  source        String
  medium        String? // raw GA medium (organic, cpc, social, referral, …)
  sessions      Int      @default(0)
  conversions   Int      @default(0)
  // Revenue when GA4 reports it (event_value / purchase events). Stored as a
  // Decimal so currency precision survives aggregation, same as AdSnapshot.spend.
  revenue       Decimal  @default(0) @db.Decimal(12, 2)

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId, date, source]) // one row per hotel per day per source
  @@index([agencyId])
  @@index([hotelClientId])
}

// ─────────────────────────────────────────────────────────────────────────────
// GA4 via OAuth — the user-consent successor to the service-account
// GoogleAnalyticsConnection above (which is retired/unused). The agency clicks
// "Connect GA4", consents on Google, and we store encrypted access+refresh
// tokens. Daily sync (lib/ga4-sync.ts) pulls a richer set than the old flow:
// traffic, acquisition channels, Google Ads, geography, device, landing pages.
//
// SECURITY: accessToken/refreshToken hold AES-256-GCM ciphertext (never
// plaintext); they're stripped from query results by the prisma scrub
// extension and read only via getTokenForApiCall (see lib/token-access.ts).
// ─────────────────────────────────────────────────────────────────────────────

enum GA4Status {
  ACTIVE
  TOKEN_EXPIRED
  ERROR
  REVOKED
}

model Ga4Connection {
  id              String    @id @default(cuid())
  hotelClientId   String    @unique // one GA4 connection per hotel
  agencyId        String
  propertyId      String // GA4 numeric property id, e.g. "123456789" ("" until picked)
  propertyName    String?
  accessToken     String    @db.Text // AES-256-GCM ciphertext. NEVER log or expose.
  refreshToken    String    @db.Text // AES-256-GCM ciphertext. NEVER log or expose.
  tokenExpiresAt  DateTime
  scope           String
  status          GA4Status @default(ACTIVE)
  lastSyncedAt    DateTime?
  lastSyncError   String?
  // Defensive surfacing: set true when token refresh / a data call returns an
  // OAuth/auth failure (e.g. a Google client-id swap orphans the refresh token)
  // so the dashboard can show a one-click reconnect banner. lastErrorReason holds
  // the raw Google error (invalid_grant / invalid_client / …). Cleared on a
  // successful (re)connect or sync.
  requiresReconnect Boolean @default(false)
  lastErrorReason   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@index([agencyId])
}

model Ga4Snapshot {
  id                 String   @id @default(cuid())
  hotelClientId      String
  agencyId           String
  date               DateTime @db.Date
  // Traffic
  sessions           Int      @default(0)
  users              Int      @default(0)
  newUsers           Int      @default(0)
  pageViews          Int      @default(0)
  bounceRate         Float    @default(0) // 0..1
  avgSessionDuration Int      @default(0) // seconds
  // Acquisition (sessionDefaultChannelGroup)
  organicSessions    Int      @default(0)
  paidSessions       Int      @default(0)
  socialSessions     Int      @default(0)
  directSessions     Int      @default(0)
  referralSessions   Int      @default(0)
  // Google Ads (google / cpc). Nullable: only present when ads run.
  googleAdsClicks      Int?
  googleAdsImpressions Int?
  googleAdsCost        Int? // paise
  googleAdsConversions Int?
  // Geographic — [{ name, sessions }, …] top 5
  topCountries    Json
  topCities       Json
  // Device
  mobileSessions  Int      @default(0)
  desktopSessions Int      @default(0)
  tabletSessions  Int      @default(0)
  // Landing pages — [{ path, sessions }, …] top 10
  topLandingPages Json

  agency      Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotelClient HotelClient @relation(fields: [hotelClientId], references: [id], onDelete: Cascade)

  @@unique([hotelClientId, date])
  @@index([hotelClientId, date])
  @@index([agencyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Data-retention safety: backfill on reconnect + sync-failure tracking.
// ─────────────────────────────────────────────────────────────────────────────

// One backfill run, kicked off when an agency reconnects a Meta/Instagram token.
// The integrations/settings UI polls this row to render live progress.
model BackfillJob {
  id           String    @id @default(cuid())
  agencyId     String
  status       String    @default("pending") // pending | running | completed | partial | failed
  rangeStart   DateTime  @db.Date
  rangeEnd     DateTime  @db.Date
  daysRestored Int       @default(0)
  daysFailed   Int       @default(0)
  message      String?
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?

  agency Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  logs   BackfillLog[]

  @@index([agencyId])
  @@index([agencyId, status])
}

// Per hotel + data type outcome of a backfill (success or failure). Failures
// carry the error so the user gets a clear summary and the next sync retries.
model BackfillLog {
  id            String   @id @default(cuid())
  agencyId      String
  hotelClientId String?
  jobId         String?
  dataType      String // ad | social | post
  dateRange     String
  status        String // success | failed
  errorMessage  String?
  createdAt     DateTime @default(now())

  agency Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  job    BackfillJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([jobId])
}

// A scheduled sync hitting an expired/invalid token. Active while resolvedAt is
// null; cleared when a successful reconnect/backfill restores the data flow.
model SyncFailure {
  id            String    @id @default(cuid())
  agencyId      String
  hotelClientId String? // null for the agency-wide Meta token
  tokenType     String // meta_ads | instagram
  failedAt      DateTime  @default(now())
  reason        String
  resolvedAt    DateTime?

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([agencyId, resolvedAt])
}

// One row per time an agency downloads or shares the setup guide PDF, so usage
// can be reported later. Multi-tenant: scoped by agencyId like every other table.
// hotelClientId is nullable — the guide may be shared from an agency-wide surface
// that isn't tied to a specific hotel.
model GuideDownload {
  id            String              @id @default(cuid())
  agencyId      String
  hotelClientId String?
  method        GuideDownloadMethod @default(direct)
  downloadedAt  DateTime            @default(now())

  agency Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  hotel  HotelClient? @relation(fields: [hotelClientId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([agencyId, downloadedAt])
}
