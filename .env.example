# ─────────────────────────────────────────────────────────────────────────────
# HotelTrack — environment variables
#
# Copy this file to `.env` (and/or `.env.local`) and fill in real values.
# NEVER commit your real `.env` file. `.env*` is gitignored (except this example).
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser; keep
# every secret WITHOUT that prefix so it stays server-only.
#
# NOTE: the placeholders below are intentionally NOT in real key formats so that
# secret scanners don't flag this template. The expected real-value prefix is
# noted in each comment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
# Primary connection string Prisma uses at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hoteltrack?schema=public"
# Only needed if DATABASE_URL points at a pooled connection (Neon, Supabase,
# Vercel Postgres, PgBouncer). Migrations require a direct connection.
# Uncomment the matching `directUrl` line in prisma/schema.prisma too.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/hoteltrack?schema=public"

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the app. Used for building UTM links, the tracking snippet
# origin, OAuth redirect URIs, and email links. No trailing slash.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
# From the Clerk dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="<your-clerk-publishable-key>"   # real value begins pk_test_ / pk_live_
CLERK_SECRET_KEY="<your-clerk-secret-key>"                         # real value begins sk_test_ / sk_live_
# Signing secret for the Clerk webhook (user.created/updated → sync to our DB).
CLERK_WEBHOOK_SECRET="<your-clerk-webhook-signing-secret>"         # real value begins whsec_
# Where Clerk's hosted sign-in / sign-up pages live in our app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# Where Clerk sends users after auth. New sign-ups go to agency onboarding;
# returning sign-ins go straight to the agency dashboard.
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/agency/onboarding"
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/agency/dashboard"

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
# From the Stripe dashboard → Developers → API keys.
STRIPE_SECRET_KEY="<your-stripe-secret-key>"                       # real value begins sk_test_ / sk_live_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="<your-stripe-publishable-key>" # real value begins pk_test_ / pk_live_
# Signing secret for the Stripe webhook endpoint (subscription lifecycle).
# Locally, `stripe listen --forward-to localhost:3001/api/webhooks/stripe`
# prints this whsec_ value.
STRIPE_WEBHOOK_SECRET="<your-stripe-webhook-signing-secret>"       # real value begins whsec_
# Monthly subscription price IDs for the three plans. Create them with
# `npm run setup:stripe` (test mode) and paste the printed IDs here.
STRIPE_PRICE_STARTER="<starter-price-id>"                          # $99/mo  · up to 3 hotels, 1 member
STRIPE_PRICE_GROWTH="<growth-price-id>"                            # $249/mo · up to 10 hotels, 5 members
STRIPE_PRICE_AGENCY="<agency-price-id>"                            # $499/mo · unlimited

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="<your-resend-api-key>"                            # real value begins re_
# Verified "from" address for transactional email.
EMAIL_FROM="HotelTrack <noreply@yourdomain.com>"

# ── Meta / Facebook (Ads API for ad ROI) ─────────────────────────────────────
# From the Meta for Developers app dashboard.
META_APP_ID="<your-meta-app-id>"
META_APP_SECRET="<your-meta-app-secret>"
# OAuth redirect URI registered in the Meta app (must match NEXT_PUBLIC_APP_URL).
META_REDIRECT_URI="http://localhost:3000/api/meta/callback"

# ── Instagram / Facebook (ORGANIC social — separate from Ads above) ──────────
# Graph API version for the organic Instagram integration (lib/instagram.ts).
# Optional; defaults to v21.0. Connecting a hotel's Instagram needs a token with
# these scopes: instagram_basic, instagram_manage_insights, pages_show_list,
# pages_read_engagement. The IG account must be Business/Creator and linked to a
# Facebook Page the token manages.
IG_GRAPH_API_VERSION="v21.0"

# ── Encryption ───────────────────────────────────────────────────────────────
# 32-byte key (AES-256) for encrypting access tokens + GA credentials at rest
# (AES-256-GCM), as a 64-character hex string.
#
# ‼  NEVER commit this. NEVER share it over Slack / email / Discord / chat.
# ‼  NEVER store it in source control. It is a root secret — anyone with it can
#    decrypt every stored token. Keep it only in your host's secret manager
#    (Vercel/Render env vars, etc.).
# ‼  Generate with:  openssl rand -hex 32
#    The app REFUSES TO START if this is missing, non-hex, or shorter than 32
#    bytes (see lib/encryption.ts assertEncryptionKeysValid).
#
# Key versioning / rotation (lib/encryption.ts): new ciphertext is written under
# ENCRYPTION_KEY_VERSION using ENCRYPTION_KEY_V<n>. v1 falls back to the legacy
# ENCRYPTION_KEY below, so existing setups keep working unchanged. To rotate, add
# ENCRYPTION_KEY_V2, set ENCRYPTION_KEY_VERSION=v2, and run `npm run rotate:keys`.
# See SECURITY.md for the full rotation + leak-response runbook.
ENCRYPTION_KEY_VERSION="v1"
ENCRYPTION_KEY_V1="<64-char-hex-string>"   # if unset, falls back to ENCRYPTION_KEY
ENCRYPTION_KEY="<64-char-hex-string>"

# Security alert recipient. When more than 3 token decryptions fail within a
# 10-minute window (possible tampering / wrong key / attack), a critical alert
# email is sent here (see lib/token-audit.ts). Leave unset to disable.
SECURITY_ALERT_EMAIL="security@yourdomain.com"

# How getTokenForApiCall() reads ciphertext (lib/token-access.ts):
#   unset/"direct" — raw SELECT (works as the table owner; default)
#   "definer"      — via the security-definer DB function. Set this ONCE the app
#                    connects as the non-owner hoteltrack_app role, whose direct
#                    SELECT of the encrypted columns is revoked.
TOKEN_SECRET_ACCESS="direct"

# ── Cron (scheduled Meta Ads sync) ───────────────────────────────────────────
# Secret guarding the daily sync endpoint at /api/meta/sync. Vercel Cron sends
# it automatically as `Authorization: Bearer <CRON_SECRET>` once it's set in the
# project's Environment Variables. Generate one with:
#   openssl rand -hex 32
CRON_SECRET="<random-secret>"
